# Server-side secrets demo for products/demo/api (PHILOSOPHY "Env/config":
# secrets live in each platform's native store — Fly secrets in deploys; locally, copy
# this to products/demo/api/.env). NEVER commit a filled .env.
#
# Runtime app traffic: Supabase TRANSACTION-mode pooler, port 6543 (Key ruling #4).
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:6543/postgres
# Alembic migrations: DIRECT connection, port 5432 (Key ruling #4).
DATABASE_MIGRATION_URL=postgresql+psycopg://postgres:postgres@localhost:5432/postgres

# Auth (Key ruling #5): JWKS is the PRIMARY verification path on ALL environments —
# point at the local Supabase stack (the current CLI issues ES256).
SUPABASE_URL=http://localhost:54421
# OPTIONAL explicit JWKS endpoint override — normally derived from SUPABASE_URL
# (<SUPABASE_URL>/auth/v1/.well-known/jwks.json); set only if an env serves JWKS elsewhere.
SUPABASE_JWKS_URL=
# HS256 fallback ONLY (older CLI / self-hosted symmetric secret / minted test tokens).
SUPABASE_JWT_SECRET=

# Realtime broadcast (Phase 8; service-role HTTP call).
SUPABASE_SERVICE_ROLE_KEY=

# CORS allowlist: web origin + app:// desktop (+ mobile origins as needed).
CORS_ORIGINS=http://localhost:8081,app://-

# Rate limiting (slowapi) default bucket.
RATE_LIMIT_DEFAULT=100/minute

ENVIRONMENT=local
